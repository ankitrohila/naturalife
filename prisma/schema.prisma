generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DISTRIBUTOR
  CUSTOMER
}

enum Language {
  EN
  HI
  BN
  TA
  TE
  MR
  GU
}

enum Material {
  PLASTIC
  RUBBER
  JUTE
  COTTON
  POLYESTER
  WOOL
  OTHER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderType {
  RETAIL
  WHOLESALE
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PACKED
  DISPATCHED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  COD
  REFUNDED
}

enum CouponType {
  FLAT
  PERCENT
  COINS
}

enum CoinLedgerType {
  EARNED
  REDEEMED
  EXPIRED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum TestimonialSource {
  GOOGLE
  MANUAL
}

enum NotificationEvent {
  ORDER_PLACED
  ORDER_DISPATCHED
  ORDER_DELIVERED
  RETURN_REQUESTED
  REFUND_DONE
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum AttributeName {
  COLOR
  SIZE
  SHAPE
  FABRIC
  MATERIAL
  HEIGHT
}

enum ContactStatus {
  NEW
  REPLIED
  CLOSED
}

// ─── Auth / User ─────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  primaryEmail      String    @unique
  primaryPhone      String    @unique
  name              String
  password          String?
  alternateEmail    String?
  alternatePhone    String?
  whatsappNumber    String?
  preferredLanguage Language  @default(HI)
  role              Role      @default(CUSTOMER)
  stateCode         String?
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  addresses    Address[]
  orders       Order[]
  coinLedger   CoinLedger[]
  couponUsages UserCouponUsage[]
  distributor  Distributor?
  mediaAssets  MediaAsset[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model Address {
  id             String   @id @default(cuid())
  userId         String
  line1          String
  line2          String?
  city           String
  state          String
  pincode        String
  country        String   @default("India")
  isDefault      Boolean  @default(false)
  phone          String
  whatsappNumber String?
  createdAt      DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── Products & Catalog ──────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  image       String?
  parentId    String?
  seoTitle    String?
  seoDesc     String?
  sortOrder   Int     @default(0)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?       @db.Text
  shortDesc   String?
  sku         String        @unique
  categoryId  String
  isFeatured  Boolean       @default(false)
  isOnSale    Boolean       @default(false)
  status      ProductStatus @default(DRAFT)
  material    Material      @default(OTHER)
  taxRate     Decimal       @default(12) @db.Decimal(5, 2)
  hsnCode     String?
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category        Category                @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  attributeValues ProductAttributeValue[]
  reviews         Review[]
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  name       String
  email      String?
  rating     Int      @default(5)
  text       String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id             String  @id @default(cuid())
  productId      String
  url            String
  altText        String?
  isPrimary      Boolean @default(false)
  colorHex       String?
  attributeValue String?
  sortOrder      Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Attribute {
  id          String        @id @default(cuid())
  name        AttributeName
  displayName String

  values                 AttributeValue[]
  productAttributeValues ProductAttributeValue[]
}

model AttributeValue {
  id          String  @id @default(cuid())
  attributeId String
  value       String
  label       String
  hexColor    String?
  imageUrl    String?
  sortOrder   Int     @default(0)

  attribute              Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  productAttributeValues ProductAttributeValue[]
}

model ProductAttributeValue {
  productId   String
  attributeId String
  valueId     String

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value     AttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId, valueId])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  sku             String   @unique
  price           Decimal  @db.Decimal(10, 2)
  wholesalePrice  Decimal  @db.Decimal(10, 2)
  minWholesaleQty Int      @default(10)
  stock           Int      @default(0)
  weight          Decimal? @db.Decimal(8, 2)
  dimensions      Json?
  attributeValues Json     @default("[]")

  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  bulkPricingRules BulkPricingRule[]
  orderItems       OrderItem[]
}

model BulkPricingRule {
  id               String  @id @default(cuid())
  productVariantId String
  minQty           Int
  maxQty           Int?
  pricePerUnit     Decimal @db.Decimal(10, 2)
  label            String?

  variant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
}

// ─── Coupons ─────────────────────────────────────────────────────────────────

model Coupon {
  id                   String     @id @default(cuid())
  code                 String     @unique
  type                 CouponType
  value                Decimal    @db.Decimal(10, 2)
  minOrderValue        Decimal?   @db.Decimal(10, 2)
  maxDiscount          Decimal?   @db.Decimal(10, 2)
  validFrom            DateTime
  validUntil           DateTime
  usageLimit           Int?
  usedCount            Int        @default(0)
  applicableProductIds Json       @default("[]")
  applicableCategoryIds Json      @default("[]")
  isActive             Boolean    @default(true)

  usages UserCouponUsage[]
}

model UserCouponUsage {
  id       String   @id @default(cuid())
  userId   String
  couponId String
  orderId  String
  usedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  coupon Coupon @relation(fields: [couponId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  userId                String
  addressId             String?
  orderType             OrderType     @default(RETAIL)
  status                OrderStatus   @default(PLACED)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethod         String?
  razorpayOrderId       String?
  razorpayPaymentId     String?
  subtotal              Decimal       @db.Decimal(10, 2)
  taxAmount             Decimal       @db.Decimal(10, 2)
  shippingCharge        Decimal       @db.Decimal(10, 2)
  discount              Decimal       @default(0) @db.Decimal(10, 2)
  coinDiscount          Decimal       @default(0) @db.Decimal(10, 2)
  total                 Decimal       @db.Decimal(10, 2)
  currency              String        @default("INR")
  assignedDistributorId String?
  stateCode             String?
  trackingNumber        String?
  trackingUrl           String?
  notes                 String?
  couponCode            String?
  coinsEarned           Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user        User                 @relation(fields: [userId], references: [id])
  address     Address?             @relation(fields: [addressId], references: [id])
  distributor Distributor?         @relation(fields: [assignedDistributorId], references: [id])
  items       OrderItem[]
  history     OrderStatusHistory[]
  couponUsage UserCouponUsage[]
  coinLedger  CoinLedger[]
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int
  unitPrice        Decimal @db.Decimal(10, 2)
  taxRate          Decimal @db.Decimal(5, 2)
  taxAmount        Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [productVariantId], references: [id])
}

model OrderStatusHistory {
  id                String      @id @default(cuid())
  orderId           String
  status            OrderStatus
  note              String?
  notifyCustomer    Boolean     @default(true)
  notifyDistributor Boolean     @default(false)
  createdAt         DateTime    @default(now())
  createdBy         String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Distributors ─────────────────────────────────────────────────────────────

model Distributor {
  id             String  @id @default(cuid())
  userId         String  @unique
  stateCodes     Json    @default("[]")
  email          String
  whatsappNumber String?
  phone          String
  companyName    String
  gstNumber      String?
  isActive       Boolean @default(true)

  user          User           @relation(fields: [userId], references: [id])
  statePincodes StatePincode[]
  orders        Order[]
}

model StatePincode {
  id            String @id @default(cuid())
  stateCode     String
  stateName     String
  pincodeFrom   Int
  pincodeTo     Int
  distributorId String

  distributor Distributor @relation(fields: [distributorId], references: [id])

  @@index([pincodeFrom, pincodeTo])
}

// ─── Loyalty ─────────────────────────────────────────────────────────────────

model CoinLedger {
  id          String         @id @default(cuid())
  userId      String
  orderId     String?
  type        CoinLedgerType
  coins       Int
  description String?
  createdAt   DateTime       @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
}

// ─── CMS & Settings ──────────────────────────────────────────────────────────

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     Json     @default("{}")
  seoTitle    String?
  seoDesc     String?
  isPublished Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id         String    @id @default(cuid())
  url        String
  publicId   String    @unique
  type       MediaType @default(IMAGE)
  altText    String?
  tags       Json      @default("[]")
  uploadedBy String?
  createdAt  DateTime  @default(now())

  uploader User? @relation(fields: [uploadedBy], references: [id])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model MarqueeOffer {
  id        String  @id @default(cuid())
  text      String
  linkUrl   String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
}

model Testimonial {
  id         String            @id @default(cuid())
  name       String
  location   String?
  rating     Int               @default(5)
  text       String            @db.Text
  imageUrl   String?
  isVerified Boolean           @default(false)
  source     TestimonialSource @default(MANUAL)
  isVisible  Boolean           @default(true)
  createdAt  DateTime          @default(now())
}

model EmailSubscription {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  isActive     Boolean  @default(true)
}

model ContactEnquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
}

model NotificationTemplate {
  id           String              @id @default(cuid())
  event        NotificationEvent
  channel      NotificationChannel
  subject      String?
  bodyTemplate String              @db.Text
  isActive     Boolean             @default(true)
  updatedAt    DateTime            @updatedAt

  @@unique([event, channel])
}

model NotificationLog {
  id        String   @id @default(cuid())
  event     String
  recipient String
  channel   String
  status    String
  preview   String?  @db.Text
  createdAt DateTime @default(now())
}
